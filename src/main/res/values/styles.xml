<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Application Theme -->
    <style name="AppTheme" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/nn_primary</item>
        <item name="colorPrimaryVariant">@color/nn_primary_dark</item>
        <item name="colorOnPrimary">@color/nn_white</item>
        <item name="colorSecondary">@color/nn_success</item>
        <item name="colorSecondaryVariant">#059669</item>
        <item name="colorOnSecondary">@color/nn_white</item>
        <item name="android:statusBarColor">@color/nn_white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/nn_white</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- Professional Typography -->
    <style name="TextAppearance.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/nn_white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/nn_gray_700</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/nn_gray_600</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextAppearance.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/nn_gray_500</item>
    </style>

    <!-- Professional Buttons -->
    <style name="Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:paddingVertical">14dp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/nn_primary</item>
        <item name="android:textColor">@color/nn_white</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingVertical">14dp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/nn_gray_200</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/nn_gray_700</item>
    </style>

    <!-- Professional Cards -->
    <style name="Card.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/nn_white</item>
    </style>

    <style name="Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">@color/nn_gray_200</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/nn_white</item>
    </style>

    <!-- Chip Styles -->
    <style name="Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_background_selector</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
