<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <!-- Modern App Bar with Gradient -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:elevation="0dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@android:color/transparent"
            android:contentInsetStart="0dp"
            android:contentInsetEnd="0dp"
            app:contentInsetStart="0dp"
            app:contentInsetEnd="0dp"
            app:contentInsetStartWithNavigation="0dp"
            app:contentInsetEndWithActions="0dp"
            app:titleTextColor="#FFFFFF"
            app:navigationIconTint="#FFFFFF"
            app:titleTextAppearance="@style/TextAppearance.Title" />

        <!-- Professional Filter Chips - Only visible in list view -->
        <HorizontalScrollView
            android:id="@+id/filterChipsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="@android:color/transparent"
            android:paddingTop="0dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/statusChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="8dp" />

        </HorizontalScrollView>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Escalations List View -->
        <FrameLayout
            android:id="@+id/escalationsContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F9FAFB">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/escalationsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:paddingHorizontal="12dp"
                android:scrollbars="none"
                android:overScrollMode="never" />

            <ProgressBar
                android:id="@+id/escalationsProgressBar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminateTint="#3B82F6"
                android:visibility="gone" />

            <!-- Premium Empty State -->
            <LinearLayout
                android:id="@+id/emptyStateLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="48dp"
                android:visibility="gone">

                <!-- Modern Icon Container with Gradient -->
                <FrameLayout
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:background="@drawable/circle_empty_state">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="💬"
                        android:textSize="64sp" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="No Live Chats"
                    android:textColor="#111827"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.01" />

                <TextView
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:lineSpacingExtra="6dp"
                    android:text="Live chat requests will appear here when customers need assistance"
                    android:textColor="#6B7280"
                    android:textSize="16sp"
                    android:alpha="0.95" />

            </LinearLayout>

        </FrameLayout>

        <!-- Chat Conversation View -->
        <FrameLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:visibility="gone">

            <!-- Messages List with Professional Spacing -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/messagesRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="72dp"
                android:clipToPadding="false"
                android:paddingTop="16dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="24dp"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:background="#FFFFFF" />

            <ProgressBar
                android:id="@+id/messagesProgressBar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminateTint="#3B82F6"
                android:visibility="gone" />

            <!-- Professional Typing Indicator -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/typingIndicatorCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="80dp"
                android:visibility="gone"
                app:cardBackgroundColor="#F3F4F6"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:gravity="center_vertical">

                    <ProgressBar
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="8dp"
                        android:indeterminateTint="#6B7280" />

                    <TextView
                        android:id="@+id/typingIndicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Customer is typing..."
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Professional Action Buttons -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/actionButtonsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginBottom="72dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="8dp"
                app:cardCornerRadius="0dp">

                <LinearLayout
                    android:id="@+id/actionButtonsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:gravity="center"
                    android:background="#FFFFFF">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/resolveButton"
                        style="@style/Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Resolve"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#10B981"
                        app:icon="@drawable/ic_check_circle"
                        app:iconGravity="textStart"
                        app:iconTint="@android:color/white"
                        app:iconSize="20dp"
                        app:elevation="2dp"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/endChatButton"
                        style="@style/Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="End Chat"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#EF4444"
                        app:icon="@drawable/ic_close_circle"
                        app:iconGravity="textStart"
                        app:iconTint="@android:color/white"
                        app:iconSize="20dp"
                        app:elevation="2dp"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Premium Input Container -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/inputContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_margin="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="12dp"
                app:cardCornerRadius="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:minHeight="72dp"
                    android:background="#FFFFFF">

                    <!-- Modern Input Field with Border -->
                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_field">

                        <EditText
                            android:id="@+id/inputField"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Type your message..."
                            android:textColorHint="#9CA3AF"
                            android:textColor="#111827"
                            android:textSize="15sp"
                            android:imeOptions="actionSend"
                            android:inputType="textCapSentences|textMultiLine"
                            android:maxLines="5"
                            android:minHeight="48dp"
                            android:paddingVertical="12dp"
                            android:paddingHorizontal="20dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif" />

                    </FrameLayout>

                    <!-- Premium Send Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/sendButton"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="12dp"
                        android:enabled="false"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        app:icon="@drawable/ic_send"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp"
                        app:iconTint="@android:color/white"
                        app:cornerRadius="28dp"
                        app:backgroundTint="#3B82F6"
                        app:elevation="4dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

    </FrameLayout>

    <!-- Professional Connection Status Banner -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/connectionStatusCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:visibility="gone"
        app:cardBackgroundColor="#F59E0B"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingVertical="14dp"
            android:gravity="center">

            <ProgressBar
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="12dp"
                android:indeterminateTint="@android:color/white" />

            <TextView
                android:id="@+id/connectionStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reconnecting..."
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
