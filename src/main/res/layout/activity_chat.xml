<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-style minimal chat layout - clean white background -->
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <!-- Simple Toolbar - iOS style -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="0dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFFFFF"
            app:titleTextColor="#000000"
            app:navigationIconTint="#4A6EE0"
            app:menu="@menu/menu_chat" />

        <!-- Subtle divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E5E7EB" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Chat Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:background="#F9FAFB">

        <!-- Messages List - iOS style clean -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="72dp"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:background="#F9FAFB" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:indeterminateTint="#4A6EE0"
            android:visibility="gone" />

        <!-- Minimal Input Container - iOS style -->
        <LinearLayout
            android:id="@+id/inputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <!-- Top divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#E5E7EB" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="#FFFFFF">

                <!-- Simple Input Field - iOS style -->
                <EditText
                    android:id="@+id/inputField"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Type a message..."
                    android:textColorHint="#9CA3AF"
                    android:textColor="#000000"
                    android:textSize="17sp"
                    android:imeOptions="actionSend"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="5"
                    android:minHeight="36dp"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="12dp"
                    android:background="@drawable/bg_input_field"
                    android:fontFamily="sans-serif" />

                <!-- Simple Send Button - iOS style -->
                <ImageButton
                    android:id="@+id/sendButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:enabled="false"
                    android:src="@drawable/ic_send"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#4A6EE0"
                    android:contentDescription="Send" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
